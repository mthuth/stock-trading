  "fundamental_target_model": {
    "version": "v1_straightforward_adjustable",
    "status": "v1_2_first_pass_implemented",
    "principles": {
      "store_defaults_in_config": true,
      "prefer_ranges_when_inputs_are_weak": true,
      "fundamental_target_alone_cannot_create_high_confidence_add": true
    },
    "growth_adjustment": {
      "pe_points_per_growth_point_above_peer_median": 0.5,
      "max_pe_adjustment": 8,
      "cyclical_margin_haircut": 0.15,
      "thin_coverage_confidence_haircut": 0.25
    },
    "target_return_defaults": {
      "mega_cap_ai_platform": {
        "base_upside_pct": 18,
        "min_upside_pct": -8,
        "max_upside_pct": 35
      },
      "semiconductors": {
        "base_upside_pct": 16,
        "min_upside_pct": -12,
        "max_upside_pct": 32
      },
      "cloud_software_cybersecurity": {
        "base_upside_pct": 22,
        "min_upside_pct": -15,
        "max_upside_pct": 40
      },
      "etf_ballast": {
        "base_upside_pct": 8,
        "min_upside_pct": -5,
        "max_upside_pct": 15
      },
      "speculative_ai": {
        "base_upside_pct": 25,
        "min_upside_pct": -25,
        "max_upside_pct": 45
      }
    },
    "quality_adjustment": {
      "basis_score": 80,
      "pct_per_score_point": 0.2,
      "max_adjustment_pct": 6
    },
    "catalyst_adjustment": {
      "basis_score": 75,
      "pct_per_score_point": 0.15,
      "max_adjustment_pct": 6
    },
    "risk_adjustment": {
      "basis_score": 75,
      "pct_per_score_point_below_basis": 0.2,
      "max_penalty_pct": 8
    },
    "margin_adjustment": {
      "strong_operating_margin": 0.25,
      "strong_cash_flow_margin": 0.20,
      "strong_margin_bonus_pct": 4,
      "negative_margin_penalty_pct": 8
    },
    "range_width_pct": {
      "high": 0.08,
      "medium": 0.12,
      "low": 0.18
    },
    "peer_groups": {
      "mega_cap_ai_platform": {
        "symbols": ["MSFT", "NVDA", "GOOGL", "AMZN", "META", "AVGO"],
        "primary_multiple": "forward_pe_or_ev_revenue",
        "default_forward_pe": 30,
        "default_ev_revenue": 8,
        "notes": "Reward durable growth, margins, and platform strength; cap growth multiple expansion."
      },
      "semiconductors": {
        "symbols": ["AMD", "ARM", "MU", "TSM", "ASML", "SMH"],
        "primary_multiple": "forward_pe_or_ev_revenue",
        "default_forward_pe": 28,
        "default_ev_revenue": 7,
        "cyclicality_haircut": 0.15,
        "notes": "Apply cyclical haircut when earnings or margins are volatile."
      },
      "cloud_software_cybersecurity": {
        "symbols": ["CRWD", "PANW", "NET", "DDOG", "SNOW", "MDB"],
        "primary_multiple": "ev_revenue_and_fcf_margin",
        "default_ev_revenue": 9,
        "notes": "Reward durable growth plus improving free cash flow margin; penalize deceleration."
      },
      "etf_ballast": {
        "symbols": ["QQQM", "VGT", "SMH"],
        "primary_multiple": "sector_basket_proxy",
        "default_target_method": "current_price_plus_model_trend_range",
        "notes": "Use conservative sector/basket proxy rather than single-company fair value."
      },
      "speculative_ai": {
        "symbols": ["SOUN", "AEHR", "BBAI", "ALAB", "PLAB"],
        "primary_multiple": "ev_revenue_or_manual_range",
        "default_ev_revenue": 4,
        "confidence_haircut": 0.35,
        "notes": "Watchlist-only until observation period and source confidence improve."
      }
    }
  },
  "blended_target_model": {
    "version": "v1_3_analyst_fundamental_technical",
    "status": "v1_3_implementation",
    "long_term_weights": {
      "analyst": 0.45,
      "fundamental": 0.45,
      "technical": 0.10
    },
    "short_term_weights": {
      "analyst": 0.20,
      "fundamental": 0.20,
      "technical": 0.60
    },
    "fallback_weights": {
      "analyst": 0.55,
      "fundamental": 0.45,
      "technical": 0.00
    },
    "confidence_rules": {
      "two_source_minimum_for_medium": true,
      "technical_target_needed_for_high": true,
      "wide_range_downgrades_confidence": true
    }
  },
  "technical_target_model": {
    "version": "v1_simple_adjustable",
    "status": "v1_3_first_pass_implemented",
    "principles": {
      "store_defaults_in_config": true,
      "prefer_ranges_when_signals_are_mixed": true,
      "technical_target_alone_cannot_create_high_confidence_add": true,
      "defer_advanced_ta_library_until_v1_is_useful": true
    },
    "windows": {
      "short_trend_days": 20,
      "medium_trend_days": 50,
      "long_trend_days": 200,
      "support_lookback_days": 60,
      "resistance_lookback_days": 60
    },
    "buffers": {
      "breakout_buffer_pct": 0.03,
      "stop_review_buffer_below_support_pct": 0.05,
      "high_volatility_confidence_haircut": 0.20,
      "thin_history_confidence_haircut": 0.25
    },
    "blended_target_caps": {
      "long_term_max_technical_contribution": 0.10,
      "short_term_max_technical_contribution": 0.45
    },
    "outputs": [
      "technical_target_low",
      "technical_target_high",
      "support_level",
      "resistance_level",
      "trend_state",
      "entry_zone",
      "stop_review_level",
      "confidence"
    ]
  },
  "evidence_ingestion": {
    "version": "v1_source_attributed_capture",
    "status": "v1_1_storage_and_ingestion_scripts_added",
    "scoring_impact": "store_and_display_first_score_later",
    "principles": {
      "sqlite_is_system_of_record": true,
      "deduplicate_by_source_identifier": true,
      "corroboration_required_for_news_opinion_social_options": true,
      "primary_sources_have_higher_reliability": true

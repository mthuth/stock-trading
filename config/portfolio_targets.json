      },
      {
        "name": "FMP stock news",
        "source_type": "news",
        "priority": 4,
        "pull_method": "fmp_news_endpoint_if_key_supports_it",
        "captures": ["headline", "url", "publisher", "published_at"],
        "initial_use": "news_fallback"
      },
      {
        "name": "Benzinga news",
        "source_type": "paid_news_candidate",
        "priority": 5,
        "pull_method": "evaluate_later_if_needed",
        "captures": ["market_moving_headlines", "analyst_rating_news"],
        "initial_use": "optional_short_term_catalyst_upgrade"

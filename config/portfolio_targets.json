        "inputs": ["ticker_to_cik_mapping"],
        "captures": ["revenue", "eps", "cash_flow", "margins", "balance_sheet_facts"],
        "initial_use": "fundamental_target_inputs_and_primary_source_validation"
      },
      {
        "name": "Company investor relations",
        "source_type": "company_release",
        "priority": 2,
        "pull_method": "configured_symbol_urls_or_manual_links",
        "captures": ["earnings_releases", "presentations", "guidance", "company_events"],
        "initial_use": "corroborate_filings_and_transcripts"
      },
      {
        "name": "FMP earnings transcripts",
        "source_type": "earnings_transcript",
        "priority": 2,
        "pull_method": "fmp_transcript_endpoint_if_key_supports_it",
        "captures": ["management_commentary", "qa", "guidance_tone", "risk_language"],
        "initial_use": "deep_research_notes_and_catalyst_confidence"
      },
      {
        "name": "Finnhub transcripts",
        "source_type": "earnings_transcript",
        "priority": 2,
        "pull_method": "finnhub_transcript_endpoints_if_key_supports_them",
        "captures": ["management_commentary", "qa", "participant_metadata"],
        "initial_use": "transcript_fallback_or_enrichment"
      },
      {
        "name": "Alpha Vantage news sentiment",
        "source_type": "news_sentiment",
        "priority": 3,
        "pull_method": "NEWS_SENTIMENT_BY_TICKER",
        "captures": ["headline", "url", "publisher", "published_at", "sentiment"],
        "initial_use": "news_catalyst_queue_and_sentiment_context"

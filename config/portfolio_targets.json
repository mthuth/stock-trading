        "captures": ["filing_metadata", "filing_urls", "10-K", "10-Q", "8-K", "20-F", "6-K"],
        "initial_use": "filing_event_timeline_and_risk_catalyst_prompts"
      },
      {
        "name": "SEC EDGAR companyfacts",
        "source_type": "sec_xbrl_facts",
        "priority": 1,
